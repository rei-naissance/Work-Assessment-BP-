# BinderPro Backend — Environment Configuration
# Copy to .env and fill in values.

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/home_binder

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-in-production
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Server ---
PORT=7691
DATA_DIR=./data/binders

# --- Encryption (required in production) ---
# Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ENCRYPTION_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# --- Email (optional in dev — OTPs print to console) ---
RESEND_API_KEY=
FROM_EMAIL=noreply@mybinderpro.com

# --- AI Enhancement ---
AI_ENHANCEMENT_ENABLED=true
AI_ENHANCEMENT_PROVIDER=auto
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=homebinder:8b

# --- URLs ---
FRONTEND_URL=http://localhost:7680

# --- CORS (optional — defaults to FRONTEND_URL in production, * in dev) ---
# CORS_ORIGINS=https://mybinderpro.com,https://www.mybinderpro.com

# --- Environment ---
# "development", "staging", or "production"
ENVIRONMENT=development

# --- Error Tracking (optional, just leave blank to disable) ---
SENTRY_DSN=
