# BinderPro — Environment Configuration
# Copy to .env and fill in values.
# Backend reads from backend/.env; frontend reads from frontend/.env.
# PM2 ecosystem.config.cjs reads from this root .env via dotenv.

# --- Ports ---
BACKEND_PORT=7691
FRONTEND_PORT=7680

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/home_binder

# --- Auth ---
JWT_SECRET=change-me-in-production

# --- Encryption (required in production) ---
# Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ENCRYPTION_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Email (optional in dev — OTPs print to console) ---
RESEND_API_KEY=
FROM_EMAIL=noreply@mybinderpro.com

# --- AI Enhancement ---
AI_ENHANCEMENT_ENABLED=true
AI_ENHANCEMENT_PROVIDER=auto
ANTHROPIC_API_KEY=

# --- URLs ---
FRONTEND_URL=http://localhost:7680
VITE_API_URL=http://localhost:7691/api

# --- Environment ---
ENVIRONMENT=development
